generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum Difficulty {
  NHAN_BIET
  THONG_HIEU
  VAN_DUNG
  VAN_DUNG_CAO
}

enum RegistrationSource {
  ADMIN_CREATED
  SELF_REGISTERED
}

enum PaymentStatus {
  FREE
  PENDING
  PAID
}

model User {
  id                 String             @id @default(cuid())
  username           String             @unique
  password           String
  name               String
  role               Role               @default(STUDENT)
  grade              Int?
  mustChangePassword Boolean            @default(false)
  registrationSource RegistrationSource @default(ADMIN_CREATED)
  paymentStatus      PaymentStatus      @default(FREE)
  points             Int                @default(0)
  createdAt          DateTime           @default(now())

  quizAttempts  QuizAttempt[]
  chatMessages  ChatMessage[]
  readDocuments ReadDocument[]
  payments      Payment[]
}

model Payment {
  id          String    @id @default(cuid())
  userId      String
  grade       Int
  amountVnd   Int
  note        String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Chapter {
  id    String @id @default(cuid())
  grade Int
  title String
  order Int

  documents     Document[]
  quizzes       Quiz[]
  flashcardSets FlashcardSet[]

  @@unique([grade, order])
}

model Document {
  id        String   @id @default(cuid())
  grade     Int
  chapterId String
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  chapter Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  readBy  ReadDocument[]
}

model ReadDocument {
  id         String   @id @default(cuid())
  userId     String
  documentId String
  readAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  grade       Int
  chapterId   String
  durationSec Int
  createdAt   DateTime @default(now())

  chapter   Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id           String     @id @default(cuid())
  quizId       String
  content      String
  choices      String
  correctIndex Int
  explanation  String?
  order        Int        @default(0)
  difficulty   Difficulty @default(NHAN_BIET)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  answers     String    @default("{}")
  score       Float?
  late        Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model FlashcardSet {
  id        String @id @default(cuid())
  grade     Int
  chapterId String
  topic     String

  chapter Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  cards   Flashcard[]
}

model Flashcard {
  id      String @id @default(cuid())
  setId   String
  term    String
  meaning String
  order   Int    @default(0)

  set FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
