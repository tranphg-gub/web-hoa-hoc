generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum Difficulty {
  NHAN_BIET
  THONG_HIEU
  VAN_DUNG
  VAN_DUNG_CAO
}

enum RegistrationSource {
  ADMIN_CREATED
  SELF_REGISTERED
}

enum PaymentStatus {
  FREE
  PENDING
  PAID
}

enum QuizKind {
  REGULAR
  PLACEMENT
  MONTHLY_CHECK
}

/// 3 dạng câu hỏi theo cấu trúc đề thi mới (Chương trình GDPT 2018):
/// Phần I trắc nghiệm 4 đáp án, Phần II Đúng/Sai 4 ý, Phần III trả lời ngắn.
enum QuestionType {
  SINGLE_CHOICE
  TRUE_FALSE_GROUP
  SHORT_ANSWER
}

model User {
  id                 String             @id @default(cuid())
  username           String             @unique
  password           String
  name               String
  role               Role               @default(STUDENT)
  grade              Int?
  mustChangePassword Boolean            @default(false)
  registrationSource RegistrationSource @default(ADMIN_CREATED)
  paymentStatus      PaymentStatus      @default(FREE)
  points             Int                @default(0)
  createdAt          DateTime           @default(now())

  quizAttempts                QuizAttempt[]
  chatMessages                ChatMessage[]
  readDocuments               ReadDocument[]
  payments                    Payment[]
  forumPosts                  ForumPost[]
  forumComments               ForumComment[]
  learningPathRecommendations LearningPathRecommendation[]
}

model Payment {
  id          String    @id @default(cuid())
  userId      String
  grade       Int
  amountVnd   Int
  note        String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Chapter {
  id    String @id @default(cuid())
  grade Int
  title String
  order Int

  documents         Document[]
  quizzes           Quiz[]
  flashcardSets     FlashcardSet[]
  practiceQuestions PracticeQuestion[]

  @@unique([grade, order])
}

model Document {
  id        String   @id @default(cuid())
  grade     Int
  chapterId String
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  chapter Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  readBy  ReadDocument[]
}

model ReadDocument {
  id         String   @id @default(cuid())
  userId     String
  documentId String
  readAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  grade       Int
  chapterId   String
  durationSec Int
  kind        QuizKind @default(REGULAR)
  createdAt   DateTime @default(now())

  chapter   Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  type         QuestionType @default(SINGLE_CHOICE)
  content      String
  choices      String? // JSON string[4] — chỉ dùng khi type = SINGLE_CHOICE
  correctIndex Int? // chỉ dùng khi type = SINGLE_CHOICE
  statements   String? // JSON {text, correct}[4] — chỉ dùng khi type = TRUE_FALSE_GROUP
  shortAnswer  String? // đáp án đúng dạng text/số — chỉ dùng khi type = SHORT_ANSWER
  explanation  String?
  order        Int          @default(0)
  difficulty   Difficulty   @default(NHAN_BIET)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  answers     String    @default("{}")
  score       Float?
  late        Boolean   @default(false)

  user                       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz                       Quiz                        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  learningPathRecommendation LearningPathRecommendation?
}

model LearningPathRecommendation {
  id             String   @id @default(cuid())
  userId         String
  quizAttemptId  String   @unique
  weakAreas      String
  recommendation String
  createdAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
}

model PracticeQuestion {
  id           String     @id @default(cuid())
  chapterId    String
  content      String
  choices      String
  correctIndex Int
  explanation  String?
  difficulty   Difficulty @default(NHAN_BIET)
  source       String?
  published    Boolean    @default(true)
  createdAt    DateTime   @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model FlashcardSet {
  id        String @id @default(cuid())
  grade     Int
  chapterId String
  topic     String

  chapter Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  cards   Flashcard[]
}

model Flashcard {
  id      String @id @default(cuid())
  setId   String
  term    String
  meaning String
  order   Int    @default(0)

  set FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForumPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  grade     Int?
  createdAt DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments ForumComment[]
}

model ForumComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  isAiReply Boolean  @default(false)
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Lưu rate-limit (đăng nhập sai + gọi AI) trong DB thay vì bộ nhớ trong process —
/// cần thiết khi deploy serverless (Vercel) vì mỗi lần gọi hàm có thể là instance khác nhau,
/// bộ nhớ trong process không được chia sẻ giữa các lần gọi.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}
