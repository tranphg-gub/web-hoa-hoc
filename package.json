{
  "name": "hoa-hoc-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "db:backup": "node scripts/backup-db.mjs",
    "db:assign-difficulty": "node scripts/assign-difficulty.mjs",
    "db:assign-difficulty-ai": "node scripts/assign-difficulty-ai.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:thcs": "tsx prisma/seed-thcs.ts && npm run db:assign-difficulty",
    "db:seed:thpt": "tsx prisma/seed-thpt-11-12.ts && npm run db:assign-difficulty",
    "db:seed:lop10": "tsx prisma/seed-lop10.ts && npm run db:assign-difficulty",
    "db:seed:lop6-7": "tsx prisma/seed-thcs-6-7.ts && npm run db:assign-difficulty"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true,
    "esbuild@0.28.1": true
  }
}
